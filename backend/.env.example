# ── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Frontend URL (for CORS and password reset email links) ────
CLIENT_URL=http://localhost:5173

# ── PostgreSQL (Render) ───────────────────────────────────────
# Get from Render.com dashboard → your PostgreSQL service → Connection String
DATABASE_URL=postgresql://user:password@host:5432/foodbridge

# ── MongoDB Atlas ─────────────────────────────────────────────
# Get from MongoDB Atlas → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/foodbridge?retryWrites=true&w=majority

# ── Redis (Upstash) ───────────────────────────────────────────
# Get from Upstash dashboard → your Redis database → Connect → ioredis
REDIS_URL=redis://default:password@host.upstash.io:6379

# ── JWT ───────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-64-character-random-hex-string-here
JWT_EXPIRES_IN=24h

# ── Cloudinary (photo storage) ────────────────────────────────
# Get from Cloudinary dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Email (Gmail SMTP via Nodemailer) ─────────────────────────
# Use a Gmail account with 2FA enabled
# Generate app password: Google Account → Security → App passwords
EMAIL_USER=yourapp@gmail.com
EMAIL_PASS=your-16-character-app-specific-password

# ── Google Maps ───────────────────────────────────────────────
# Get from Google Cloud Console → APIs & Services → Credentials
# Enable: Maps JavaScript API, Places API, Geocoding API
VITE_GOOGLE_MAPS_KEY=your-google-maps-api-key