# Server
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:5173

# PostgreSQL — get from Render.com dashboard
DATABASE_URL=postgresql://user:password@host:5432/foodbridge

# MongoDB — get from MongoDB Atlas dashboard
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/foodbridge?retryWrites=true&w=majority

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-32-character-random-string-here
JWT_EXPIRES_IN=7d

# Redis — get from Upstash dashboard
REDIS_URL=redis://default:password@host.upstash.io:6379

# Cloudinary — get from cloudinary.com dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# SendGrid — get from sendgrid.com dashboard
SENDGRID_API_KEY=SG.your-api-key
SENDGRID_FROM_EMAIL=noreply@foodbridge.app

# Google Maps — get from Google Cloud Console
GOOGLE_MAPS_API_KEY=AIzaSy-your-key